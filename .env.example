# Supabase konfiqurasiyası.
# Bu faylı `.env.local` adı ilə kopyalayın və real dəyərləri yazın.
# Dəyərləri Supabase layihənizin panelindən götürün: Settings > API.
# Qeyd: `.env.local` git-ə əlavə olunmur (gizli qalır).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
